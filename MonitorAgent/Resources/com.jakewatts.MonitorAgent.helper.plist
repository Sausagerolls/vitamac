<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- LaunchDaemon for the privileged helper, registered via SMAppService.daemon.
     Must live in the app at Contents/Library/LaunchDaemons/ and be inside the
     signed bundle. BundleProgram is relative to the app bundle. -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jakewatts.MonitorAgent.helper</string>
    <key>BundleProgram</key>
    <string>Contents/MacOS/MonitorHelper</string>
    <key>MachServices</key>
    <dict>
        <key>com.jakewatts.MonitorAgent.helper</key>
        <true/>
    </dict>
    <key>AssociatedBundleIdentifiers</key>
    <array>
        <string>com.jakewatts.MonitorAgent</string>
    </array>
</dict>
</plist>
